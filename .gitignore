*.py[cod]
*.egg-info/
.venv/
venv/
env/
.Python

# ─── Jupyter ───
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# ─── Notebooks con outputs ejecutados (solo local, no se publica) ───
